# OS-Baka Production Environment Configuration
# Copy this file to .env and fill in the values before deploying.

# Database
POSTGRES_PASSWORD=your_strong_password_here

# JWT Secret Key (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# Admin initial password (used only on first startup if no admin exists)
ADMIN_PASSWORD=your_admin_password_here

# External IP for PXE services
EXTERNAL_IP=10.31.0.3

# Frontend port (default: 80)
FRONTEND_PORT=80

# Vault integration (optional — uncomment to enable)
# VAULT_ENABLED=true
# VAULT_ADDR=http://vault:8200
# VAULT_TOKEN=your-vault-token
