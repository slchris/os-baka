ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# PXE Service
TFTP_ROOT=/var/lib/tftpboot
DHCP_RANGE_START=192.168.1.100
DHCP_RANGE_END=192.168.1.200
